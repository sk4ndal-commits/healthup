<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true" />
  </xsd:schema>
  <resheader name="resmimetype"><value>text/microsoft-resx</value></resheader>
  <resheader name="version"><value>2.0</value></resheader>
  <resheader name="reader"><value>System.Resources.ResXResourceReader</value></resheader>
  <resheader name="writer"><value>System.Resources.ResXResourceWriter</value></resheader>

  <!-- Auth errors -->
  <data name="InvalidCredentials" xml:space="preserve"><value>Ungültige E-Mail-Adresse oder falsches Passwort.</value></data>
  <data name="EmailAlreadyInUse" xml:space="preserve"><value>Diese E-Mail-Adresse wird bereits verwendet.</value></data>
  <data name="InvalidOrExpiredToken" xml:space="preserve"><value>Ungültiger oder abgelaufener Token.</value></data>
  <data name="PasswordChangeFailed" xml:space="preserve"><value>Passwortänderung fehlgeschlagen.</value></data>
  <data name="TodoNotFound" xml:space="preserve"><value>Aufgabe nicht gefunden.</value></data>

  <!-- Validation: common -->
  <data name="FieldRequired" xml:space="preserve"><value>'{PropertyName}' ist erforderlich.</value></data>
  <data name="InvalidEmail" xml:space="preserve"><value>'{PropertyName}' muss eine gültige E-Mail-Adresse sein.</value></data>
  <data name="MinLength" xml:space="preserve"><value>'{PropertyName}' muss mindestens {MinLength} Zeichen lang sein.</value></data>
  <data name="MaxLength" xml:space="preserve"><value>'{PropertyName}' darf maximal {MaxLength} Zeichen lang sein.</value></data>
  <data name="GreaterThan" xml:space="preserve"><value>'{PropertyName}' muss größer als {ComparisonValue} sein.</value></data>
</root>
